{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama-cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LLama.cpp (ROCm Strix Halo)",
      "options": {
        "baseURL": "http://astrolabe:8000/v1"
      },
      "models": {
        "qwen3.5-122b-ud-q4_k_xl": {
          "name": "Qwen3.5 122B A10B UD Q4_K_XL (128K context)",
          "limit": {
            "context": 131072,
            "output": 4096
          }
        }
      }
    }
  },
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "read": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
  },
  "plugin": ["@tarquinen/opencode-dcp@latest"],
  "compaction": {
    "auto": true,
    "prune": true,
    "strategy": "summarize",
    "threshold": 0.7,
    "preserveRecentMessages": 20,
    "reserved": 20000
  }
}
