{
  "autoupdate": false,
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "vllm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "vLLM (Astrolabe)",
      "options": {
        "baseURL": "http://astrolabe:8000/v1",
        "apiKey": "dummy"
      },
      "models": {
        "Qwen3.6-27B-UD-Q8_K_XL": {
          "name": "Qwen 3.6 27B",
          "limit": {
            "context": 256000,
            "output": 16384
          }
        },
        "Qwen3.6-35B-A3B-Q8_0": {
          "name": "Qwen 3.6 35B A3B",
          "limit": {
            "context": 256000,
            "output": 16384
          }
        }
      }
    }
  },
  "agent": {
    "yolo": {
      "description": "Dangerously skip permissions for local homelab automation",
      "instructions": "You are an expert NixOS and Systems Engineer. You have full permission to modify files, run shell commands within your directory. Prioritize concise, correct solutions.",
      "permission": {
        "*": {
          "*": "allow"
        },
        "bash": "allow",
        "edit": "allow"
      }
    }
  },
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "read": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow"
  },
  "compaction": {
    "auto": false,
    "prune": false,
    "strategy": "truncate",
    "threshold": 0.7,
    "preserveRecentMessages": 20,
    "reserved": 20000
  }
}
