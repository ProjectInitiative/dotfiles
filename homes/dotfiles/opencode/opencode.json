{
  "autoupdate": false,
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "fox": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "fox (Astrolabe)",
      "options": {
        "baseURL": "http://astrolabe:8000/v1",
        "apiKey": "dummy"
      },
      "models": {
        "Qwen3.6-27B-UD-Q8_K_XL": {
          "name": "Qwen 3.6 27B",
          "limit": {
            "context": 256000,
            "output": 16384
          }
        },
        "Qwen3.6-35B-A3B-Q8_0": {
          "name": "Qwen 3.6 35B A3B",
          "limit": {
            "context": 256000,
            "output": 16384
          }
        }
      }
    }
  },
  "agent": {
    "yolo": {
      "description": "Dangerously skip permissions for local homelab automation",
      "permission": {
        "*": "allow"
      }
    }
  },
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "read": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow"
  },
  "mcp": {
    "k8s-cc": {
      "type": "remote",
      "url": "http://100.90.79.119/sse"
    },
    "k8s-mc": {
      "type": "remote",
      "url": "http://100.85.160.67/sse"
    }
  },
  "compaction": {
    "auto": false,
    "prune": false,
    "strategy": "truncate",
    "threshold": 0.7,
    "preserveRecentMessages": 20,
    "reserved": 20000
  }
}
