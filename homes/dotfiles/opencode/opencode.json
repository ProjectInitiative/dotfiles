{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "vllm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "vLLM (Astrolabe)",
      "options": {
        "baseURL": "http://astrolabe:8000/v1",
        "apiKey": "dummy"
      },
      "models": {
        "astrolabe": {
          "name": "astrolabe (256k context)",
          "limit": {
            "context": 256000,
            "output": 16384
          },
          "parameters": {
            "repetition_penalty": 1.02
          }
        }
      }
    }
  },
  "agent": {
    "yolo": {
      "description": "Dangerously skip permissions for local homelab automation",
      "instructions": "You are an expert NixOS and Systems Engineer. You have full permission to modify files, run shell commands within your directory. Prioritize concise, correct solutions.",
      "permission": {
        "*": {
          "*": "allow"
        },
        "bash": "allow",
        "edit": "allow" 
      }
    }
  },
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "read": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow"
  },
  "compaction": {
    "auto": false,
    "prune": false,
    "strategy": "truncate",
    "threshold": 0.7,
    "preserveRecentMessages": 20,
    "reserved": 20000
  }
}